<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SMKN 7 Semarang — Jadwal Siswa</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --red: #C0392B;
    --red-dark: #96281B;
    --red-light: #E74C3C;
    --gold: #F39C12;
    --gold-light: #F1C40F;
    --cream: #FDF6EC;
    --bg: #F7F3EE;
    --white: #FFFFFF;
    --gray-50: #FAFAFA;
    --gray-100: #F0EFED;
    --gray-200: #E4E2DF;
    --gray-400: #9C9893;
    --gray-600: #625F5A;
    --gray-800: #2C2A27;
    --dark: #1A1816;
    --shadow-sm: 0 1px 4px rgba(0,0,0,0.08);
    --shadow: 0 4px 20px rgba(0,0,0,0.1);
    --shadow-lg: 0 12px 40px rgba(0,0,0,0.15);
    --radius: 16px;
    --radius-sm: 10px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: var(--bg);
    color: var(--gray-800);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ─── SCREENS ─── */
  .screen { display: none; min-height: 100vh; }
  .screen.active { display: flex; flex-direction: column; }

  /* ─── LOGIN SCREEN ─── */
  #screen-login {
    background: var(--dark);
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .login-bg {
    position: absolute; inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse at 20% 50%, rgba(192,57,43,0.3) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(243,156,18,0.2) 0%, transparent 50%);
  }

  .login-grid {
    position: absolute; inset: 0;
    pointer-events: none;
    background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
                      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .login-card {
    position: relative; z-index: 2;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(20px);
    border-radius: 24px;
    padding: 48px 40px;
    width: 100%; max-width: 440px;
    margin: 20px;
    animation: fadeUp 0.6s ease;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .school-logo {
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 36px;
  }

  .logo-shield {
    width: 52px; height: 52px;
    background: linear-gradient(135deg, var(--red), var(--red-dark));
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Space Mono', monospace;
    font-size: 18px; font-weight: 700;
    color: white;
    box-shadow: 0 4px 20px rgba(192,57,43,0.5);
    flex-shrink: 0;
  }

  .school-name { color: white; }
  .school-name h1 { font-size: 16px; font-weight: 700; line-height: 1.2; }
  .school-name p { font-size: 12px; color: rgba(255,255,255,0.5); margin-top: 2px; }

  .login-title {
    color: white; font-size: 28px; font-weight: 800;
    margin-bottom: 6px; letter-spacing: -0.5px;
  }
  .login-subtitle { color: rgba(255,255,255,0.45); font-size: 14px; margin-bottom: 32px; }

  .form-group { margin-bottom: 20px; }
  .form-group label {
    display: block; color: rgba(255,255,255,0.6);
    font-size: 12px; font-weight: 600; letter-spacing: 0.08em;
    text-transform: uppercase; margin-bottom: 8px;
  }
  .form-group input, .form-group select {
    width: 100%; padding: 14px 16px;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius-sm);
    color: white; font-size: 15px;
    font-family: inherit;
    outline: none; transition: all 0.2s;
  }
  .form-group input::placeholder { color: rgba(255,255,255,0.25); }
  .form-group input:focus, .form-group select:focus {
    border-color: var(--red-light);
    background: rgba(192,57,43,0.12);
  }
  .form-group select option { background: #2C2A27; color: white; }

  .btn-login {
    width: 100%; padding: 16px;
    background: linear-gradient(135deg, var(--red-light), var(--red-dark));
    border: none; border-radius: var(--radius-sm);
    color: white; font-size: 15px; font-weight: 700;
    font-family: inherit; cursor: pointer;
    transition: all 0.2s; margin-top: 8px;
    box-shadow: 0 4px 20px rgba(192,57,43,0.4);
  }
  .btn-login:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 28px rgba(192,57,43,0.5);
  }
  .btn-login:active { transform: translateY(0); }

  /* ─── MAIN APP ─── */
  #screen-app { background: var(--bg); }

  /* Header */
  .app-header {
    background: var(--dark);
    padding: 0 20px;
    position: sticky; top: 0; z-index: 100;
    box-shadow: 0 2px 20px rgba(0,0,0,0.2);
  }

  .header-top {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 0;
  }

  .header-logo { display: flex; align-items: center; gap: 10px; }
  .header-logo .logo-mini {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--red), var(--red-dark));
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Space Mono', monospace; font-size: 13px;
    font-weight: 700; color: white;
  }
  .header-logo span { color: white; font-weight: 700; font-size: 14px; }

  .header-user { display: flex; align-items: center; gap: 10px; }
  .user-avatar {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    border-radius: 50%; display: flex; align-items: center;
    justify-content: center; font-weight: 700; font-size: 14px;
    color: var(--dark); flex-shrink: 0;
  }
  .user-info { color: white; }
  .user-info .name { font-weight: 700; font-size: 13px; line-height: 1; }
  .user-info .class { font-size: 11px; color: rgba(255,255,255,0.45); margin-top: 2px; }

  .btn-logout {
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px; color: rgba(255,255,255,0.6); padding: 6px 12px;
    font-size: 12px; cursor: pointer; font-family: inherit;
    transition: all 0.2s; margin-left: 4px;
  }
  .btn-logout:hover { background: rgba(192,57,43,0.3); color: white; }

  /* Nav tabs */
  .app-nav {
    display: flex; gap: 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .nav-tab {
    flex: 1; padding: 12px 6px;
    background: none; border: none; color: rgba(255,255,255,0.4);
    font-size: 11px; font-weight: 600; font-family: inherit;
    cursor: pointer; transition: all 0.2s; text-align: center;
    border-bottom: 2px solid transparent; letter-spacing: 0.04em;
    display: flex; flex-direction: column; align-items: center; gap: 4px;
  }
  .nav-tab .tab-icon { font-size: 18px; }
  .nav-tab.active { color: var(--gold); border-bottom-color: var(--gold); }
  .nav-tab:hover:not(.active) { color: rgba(255,255,255,0.7); }

  /* Tab content */
  .tab-content { display: none; flex: 1; }
  .tab-content.active { display: block; }

  /* ─── TODAY SECTION ─── */
  .today-section { padding: 20px; }

  .day-selector {
    display: flex; gap: 8px; margin-bottom: 20px;
    overflow-x: auto; padding-bottom: 4px;
    scrollbar-width: none;
  }
  .day-selector::-webkit-scrollbar { display: none; }

  .day-pill {
    flex-shrink: 0; padding: 8px 16px;
    border-radius: 100px; border: 1.5px solid var(--gray-200);
    background: white; color: var(--gray-600);
    font-size: 13px; font-weight: 600; cursor: pointer;
    transition: all 0.2s; font-family: inherit;
  }
  .day-pill.active {
    background: var(--red); border-color: var(--red);
    color: white; box-shadow: 0 4px 12px rgba(192,57,43,0.3);
  }
  .day-pill:hover:not(.active) { border-color: var(--gray-400); }

  /* Date Banner */
  .date-banner {
    background: linear-gradient(135deg, var(--red), var(--red-dark));
    border-radius: var(--radius); padding: 20px;
    color: white; margin-bottom: 20px;
    display: flex; align-items: center; justify-content: space-between;
    box-shadow: 0 6px 24px rgba(192,57,43,0.3);
  }
  .date-banner .date-main { font-size: 28px; font-weight: 800; letter-spacing: -1px; }
  .date-banner .date-sub { font-size: 13px; color: rgba(255,255,255,0.7); margin-top: 2px; }
  .date-banner .lesson-count {
    background: rgba(255,255,255,0.15); border-radius: 12px;
    padding: 10px 16px; text-align: center;
  }
  .date-banner .lesson-count span { display: block; }
  .date-banner .lesson-count .num { font-size: 24px; font-weight: 800; }
  .date-banner .lesson-count .lbl { font-size: 11px; opacity: 0.75; }

  /* Schedule cards */
  .schedule-list { display: flex; flex-direction: column; gap: 10px; }

  .schedule-card {
    background: white; border-radius: var(--radius-sm);
    padding: 16px; display: flex; gap: 14px; align-items: flex-start;
    box-shadow: var(--shadow-sm); border: 1px solid var(--gray-100);
    transition: all 0.2s; position: relative; overflow: hidden;
  }
  .schedule-card:hover { box-shadow: var(--shadow); transform: translateY(-1px); }

  .schedule-card.active-class {
    border-color: var(--red-light);
    box-shadow: 0 0 0 2px rgba(192,57,43,0.15), var(--shadow);
  }
  .schedule-card.active-class::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px;
    background: linear-gradient(to bottom, var(--red-light), var(--red));
  }
  .schedule-card.done { opacity: 0.6; }
  .schedule-card.done .scard-time { text-decoration: line-through; }

  .scard-time-block { flex-shrink: 0; text-align: right; min-width: 58px; }
  .scard-start { font-family: 'Space Mono', monospace; font-size: 14px; font-weight: 700; color: var(--gray-800); }
  .scard-end { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--gray-400); margin-top: 2px; }

  .scard-divider { width: 1px; background: var(--gray-200); align-self: stretch; flex-shrink: 0; }

  .scard-body { flex: 1; }
  .scard-subject { font-size: 15px; font-weight: 700; color: var(--gray-800); margin-bottom: 4px; }
  .scard-meta { font-size: 12px; color: var(--gray-400); }
  .scard-meta span { margin-right: 10px; }

  .scard-badge {
    flex-shrink: 0; padding: 4px 10px; border-radius: 100px;
    font-size: 10px; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .badge-ongoing { background: rgba(192,57,43,0.12); color: var(--red); }
  .badge-next { background: rgba(243,156,18,0.15); color: #D68910; }
  .badge-done { background: var(--gray-100); color: var(--gray-400); }

  .empty-state {
    text-align: center; padding: 48px 20px;
    color: var(--gray-400);
  }
  .empty-state .emoji { font-size: 48px; margin-bottom: 12px; }
  .empty-state p { font-size: 15px; }

  /* ─── SCHEDULE TAB ─── */
  .schedule-section { padding: 20px; }

  .section-title {
    font-size: 18px; font-weight: 800; color: var(--gray-800);
    margin-bottom: 16px; letter-spacing: -0.3px;
  }
  .section-title span { color: var(--red); }

  .week-grid { display: flex; flex-direction: column; gap: 12px; }

  .day-card {
    background: white; border-radius: var(--radius);
    overflow: hidden; box-shadow: var(--shadow-sm);
    border: 1px solid var(--gray-100);
  }
  .day-card-header {
    padding: 14px 16px;
    display: flex; align-items: center; justify-content: space-between;
    cursor: pointer; transition: background 0.2s;
  }
  .day-card-header:hover { background: var(--gray-50); }
  .day-card-header.today-header { background: linear-gradient(135deg, var(--red), var(--red-dark)); }
  .day-card-header.today-header .day-name,
  .day-card-header.today-header .lesson-badge { color: white; }
  .day-card-header.today-header .lesson-badge { background: rgba(255,255,255,0.2); }

  .day-name { font-size: 14px; font-weight: 700; }
  .lesson-badge {
    background: var(--gray-100); color: var(--gray-600);
    font-size: 11px; font-weight: 600; padding: 3px 10px;
    border-radius: 100px;
  }

  .day-card-body { padding: 0 16px 16px; }

  .mini-schedule { display: flex; flex-direction: column; gap: 8px; margin-top: 12px; }
  .mini-row {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 12px; border-radius: 8px; background: var(--gray-50);
  }
  .mini-time {
    font-family: 'Space Mono', monospace; font-size: 11px;
    color: var(--gray-400); width: 80px; flex-shrink: 0;
  }
  .mini-subject { font-size: 13px; font-weight: 600; color: var(--gray-800); flex: 1; }
  .mini-room { font-size: 11px; color: var(--gray-400); }

  /* ─── REMINDER TAB ─── */
  .reminder-section { padding: 20px; }

  .reminder-form {
    background: white; border-radius: var(--radius);
    padding: 20px; margin-bottom: 24px;
    box-shadow: var(--shadow-sm); border: 1px solid var(--gray-100);
  }
  .reminder-form h3 {
    font-size: 15px; font-weight: 700; margin-bottom: 16px; color: var(--gray-800);
  }

  .form-row { display: flex; gap: 12px; }
  .form-row .form-field { flex: 1; }

  .form-field { margin-bottom: 14px; }
  .form-field label {
    display: block; font-size: 11px; font-weight: 700;
    color: var(--gray-400); text-transform: uppercase;
    letter-spacing: 0.08em; margin-bottom: 6px;
  }
  .form-field input, .form-field select, .form-field textarea {
    width: 100%; padding: 11px 14px;
    border: 1.5px solid var(--gray-200); border-radius: var(--radius-sm);
    font-size: 14px; font-family: inherit; color: var(--gray-800);
    background: var(--gray-50); outline: none; transition: all 0.2s;
  }
  .form-field input:focus, .form-field select:focus, .form-field textarea:focus {
    border-color: var(--red-light); background: white;
    box-shadow: 0 0 0 3px rgba(192,57,43,0.1);
  }
  .form-field textarea { resize: vertical; min-height: 72px; }

  .btn-add {
    width: 100%; padding: 13px;
    background: linear-gradient(135deg, var(--red-light), var(--red));
    border: none; border-radius: var(--radius-sm);
    color: white; font-size: 14px; font-weight: 700;
    font-family: inherit; cursor: pointer; transition: all 0.2s;
  }
  .btn-add:hover { box-shadow: 0 6px 20px rgba(192,57,43,0.35); transform: translateY(-1px); }

  /* Reminder list */
  .reminders-list { display: flex; flex-direction: column; gap: 10px; }

  .reminder-card {
    background: white; border-radius: var(--radius-sm);
    padding: 16px; display: flex; gap: 14px; align-items: flex-start;
    box-shadow: var(--shadow-sm); border: 1px solid var(--gray-100);
    transition: all 0.2s;
  }
  .reminder-icon {
    width: 40px; height: 40px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; flex-shrink: 0;
  }
  .icon-pelajaran { background: rgba(192,57,43,0.1); }
  .icon-tugas { background: rgba(243,156,18,0.15); }
  .icon-ujian { background: rgba(52,152,219,0.12); }
  .icon-lainnya { background: var(--gray-100); }

  .reminder-body { flex: 1; }
  .reminder-title { font-size: 14px; font-weight: 700; margin-bottom: 3px; }
  .reminder-desc { font-size: 12px; color: var(--gray-400); margin-bottom: 6px; }
  .reminder-time-badge {
    display: inline-flex; align-items: center; gap: 4px;
    background: var(--gray-100); border-radius: 6px;
    padding: 3px 8px; font-size: 11px; color: var(--gray-600); font-weight: 600;
  }

  .btn-delete-reminder {
    background: none; border: none; cursor: pointer;
    color: var(--gray-400); font-size: 16px; padding: 4px;
    transition: color 0.2s;
  }
  .btn-delete-reminder:hover { color: var(--red); }

  /* ─── TOAST NOTIFICATION ─── */
  .toast-container {
    position: fixed; top: 20px; right: 20px; z-index: 9999;
    display: flex; flex-direction: column; gap: 10px; max-width: 320px;
  }
  .toast {
    background: var(--dark); color: white;
    border-radius: 14px; padding: 14px 16px;
    display: flex; gap: 12px; align-items: flex-start;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    border-left: 4px solid var(--red);
    animation: slideIn 0.3s ease;
  }
  @keyframes slideIn {
    from { opacity: 0; transform: translateX(60px); }
    to { opacity: 1; transform: translateX(0); }
  }
  .toast.hide { animation: slideOut 0.3s ease forwards; }
  @keyframes slideOut {
    to { opacity: 0; transform: translateX(60px); }
  }
  .toast-icon { font-size: 22px; flex-shrink: 0; }
  .toast-text .toast-title { font-weight: 700; font-size: 13px; }
  .toast-text .toast-body { font-size: 12px; color: rgba(255,255,255,0.65); margin-top: 2px; }

  /* ─── PERMISSION BANNER ─── */
  .notif-banner {
    background: linear-gradient(135deg, rgba(243,156,18,0.15), rgba(243,156,18,0.05));
    border: 1.5px solid rgba(243,156,18,0.4);
    border-radius: var(--radius-sm); padding: 14px 16px;
    display: flex; gap: 12px; align-items: center;
    margin-bottom: 16px;
  }
  .notif-banner .nb-icon { font-size: 24px; }
  .notif-banner .nb-text { flex: 1; font-size: 13px; color: var(--gray-800); }
  .notif-banner .nb-text strong { display: block; margin-bottom: 2px; }
  .btn-enable-notif {
    background: var(--gold); border: none; border-radius: 8px;
    padding: 8px 14px; font-size: 12px; font-weight: 700;
    font-family: inherit; cursor: pointer; color: var(--dark); flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 400px) {
    .login-card { padding: 36px 24px; }
    .form-row { flex-direction: column; }
  }
</style>
</head>
<body>

<!-- ─── SCREEN: LOGIN ─── -->
<div id="screen-login" class="screen active">
  <div class="login-bg"></div>
  <div class="login-grid"></div>
  <div class="login-card">
    <div class="school-logo">
      <div class="logo-shield">N7</div>
      <div class="school-name">
        <h1>SMK Negeri 7 Semarang</h1>
        <p>Sistem Jadwal Siswa</p>
      </div>
    </div>
    <h2 class="login-title">Selamat Datang</h2>
    <p class="login-subtitle">Masuk untuk melihat jadwal & pengingat kamu</p>

    <div class="form-group">
      <label>Nama Lengkap</label>
      <input type="text" id="inp-nama" placeholder="contoh: Ahmad Rizky Pratama" />
    </div>
    <div class="form-group">
      <label>NIS (Nomor Induk Siswa)</label>
      <input type="text" id="inp-nis" placeholder="contoh: 2324001234" />
    </div>
    <div class="form-group">
      <label>Kelas</label>
      <select id="inp-kelas">
        <option value="">— Pilih Kelas —</option>
        <option value="X PPLG 1">X PPLG 1</option>
        <option value="X PPLG 2">X PPLG 2</option>
        <option value="X PPLG 3">X PPLG 3</option>
        <option value="XI SIJA 1">XI SIJA 1</option>
        <option value="XI SIJA 2">XI SIJA 2</option>
        <option value="XI SIJA 3">XI SIJA 3</option>
        <option value="XII SIJA 1">XII SIJA 1</option>
        <option value="XII SIJA 2">XII SIJA 2</option>
        <option value="XII SIJA 3">XII SIJA 3</option>
        <option value="X KBPS 1">X KBPS 1</option>
        <option value="X KBPS 2">X KBPS 2</option>
        <option value="XI KJIJ 1">XI KJIJ 1</option>
        <option value="XI KJIJ 2">XI KJIJ 2</option>
        <option value="XII KJIJ 1">XII KJIJ 1</option>
        <option value="XII KJIJ 2">XII KJIJ 2</option>
        <option value="X TKP 1">X TKP 1</option>
        <option value="X TKP 2">X TKP 2</option>
        <option value="XI KGS 1">XI KGS 1</option>
        <option value="XI KGS 2">XI KGS 2</option>
        <option value="XII KGS 1">XII KGS 1</option>
        <option value="XII KGS 2">XII KGS 2</option>
        <option value="X TKL 1">X TKL 1</option>
        <option value="X TKL 2">X TKL 2</option>
        <option value="XI TITL 1">XI TITL 1</option>
        <option value="XI TITL 2">XI TITL 2</option>
        <option value="XII TITL 1">XII TITL 1</option>
        <option value="XII TITL 2">XII TITL 2</option>
        <option value="X TE 1">X TE 1</option>
        <option value="X TE 2">X TE 2</option>
        <option value="X TE 3">X TE 3</option>
        <option value="X TE 4">X TE 4</option>
        <option value="X TE 5">X TE 5</option>
        <option value="X TE 6">X TE 6</option>
        <option value="XI TEK 1">XI TEK 1</option>
        <option value="XI TEK 2">XI TEK 2</option>
        <option value="XI TEK 3">XI TEK 3</option>
        <option value="XI TME 1">XI TME 1</option>
