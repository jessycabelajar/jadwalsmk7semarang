const DAYS = ['Senin','Selasa','Rabu','Kamis','Jumat'];
const DAYS_EN = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday'];
const DAYS_ID = ['Minggu','Senin','Selasa','Rabu','Kamis','Jumat'];

// ─── STATE ───
let currentUser = null;
let reminders = [];
let selectedDay = null;
let notifInterval = null;

// ─── LOGIN ───
function doLogin() {
  const nama    = (document.getElementById('inp-nama').value || '').trim();
  const nis     = (document.getElementById('inp-nis').value  || '').trim();
  const kelas   = document.getElementById('inp-kelas').value   || '';
  const jurusan = document.getElementById('inp-jurusan').value || '';

  if (!nama)    { alert('Mohon isi Nama Lengkap');      return; }
  if (!nis)     { alert('Mohon isi NIS');               return; }
  if (!kelas)   { alert('Mohon pilih Kelas');           return; }
  if (!jurusan) { alert('Mohon pilih Jurusan');         return; }

  currentUser = { nama, nis, kelas, jurusan };
  savedReminders();
  initApp();
}

function doLogout() {
  currentUser = null;
  document.getElementById('screen-login').classList.add('active');
  document.getElementById('screen-app').classList.remove('active');
  clearInterval(notifInterval);
}

// ─── INIT APP ───
function initApp() {
  try {
    document.getElementById('screen-login').classList.remove('active');
    document.getElementById('screen-app').classList.add('active');

    // Display user
    document.getElementById('disp-name').textContent = currentUser.nama;
    document.getElementById('disp-class').textContent = `Kelas ${currentUser.kelas} — ${currentUser.jurusan}`;
    document.getElementById('user-avatar').textContent = currentUser.nama.charAt(0).toUpperCase();

    // Build day selector
    buildDaySelector();
    // Set today
    const todayIndex = new Date().getDay();
    const todayName = DAYS_ID[todayIndex];
    const dayToSelect = DAYS.includes(todayName) ? todayName : 'Senin';
    selectDay(dayToSelect);

    // Build week view
    buildWeekGrid();

    // Load reminders
    loadReminders();
    renderReminders();

    // Check notification
    checkNotifPermission();

    // Start reminder checker
    clearInterval(notifInterval);
    notifInterval = setInterval(checkReminders, 30000);

    showToast('👋', `Selamat Datang!`, `Halo, ${currentUser.nama.split(' ')[0]}!`);
  } catch(e) {
    alert('Error saat masuk: ' + e.message);
    console.error(e);
  }
}

// ─── HELPER: get schedule for current user ───
function getUserSchedule(day) {
  // Cari jadwal berdasarkan nama kelas di semua jurusan
  for (const jurusan in JADWAL) {
    const kelasData = JADWAL[jurusan][currentUser.kelas];
    if (kelasData) {
      return kelasData[day] || [];
    }
  }
  return [];
}

// ─── EXPAND SCHEDULE ITEMS ───
function expandSchedule(items) {
  const result = [];
  items.forEach(item => {
    const jNums = item.j;
    const start = JAM[jNums[0]].s;
    const end   = JAM[jNums[jNums.length-1]].e;
    result.push({ ...item, start, end });
  });
  return result;
}

// ─── BUILD DAY SELECTOR ───
function buildDaySelector() {
  const container = document.getElementById('day-selector');
  container.innerHTML = '';
  DAYS.forEach(d => {
    const btn = document.createElement('button');
    btn.className = 'day-pill';
    btn.textContent = d;
    btn.dataset.day = d;
    btn.onclick = () => selectDay(d);
    container.appendChild(btn);
  });
}

function selectDay(day) {
  selectedDay = day;
  // Update pills
  document.querySelectorAll('.day-pill').forEach(p => {
    p.classList.toggle('active', p.dataset.day === day);
  });
  renderTodaySchedule(day);
}

// ─── RENDER TODAY SCHEDULE ───
function renderTodaySchedule(day) {
  const items = expandSchedule(getUserSchedule(day));
  const now = new Date();
  const nowMin = now.getHours() * 60 + now.getMinutes();

  // Banner
  const dayNames = { Senin:'Senin', Selasa:'Selasa', Rabu:'Rabu', Kamis:'Kamis', Jumat:'Jumat', Sabtu:'Sabtu' };
  document.getElementById('banner-day').textContent = day;
  document.getElementById('banner-date').textContent = formatDateID(now);
  document.getElementById('banner-count').textContent = items.length;

  const list = document.getElementById('today-list');
  list.innerHTML = '';

  if (items.length === 0) {
    list.innerHTML = `<div class="empty-state"><div class="emoji">🎉</div><p>Tidak ada jadwal pelajaran hari ini</p></div>`;
    return;
  }

  // Check if this is today
  const todayName = DAYS_ID[now.getDay()];
  const isToday = day === todayName;

  items.forEach(item => {
    const [sh, sm] = item.start.split(':').map(Number);
    const [eh, em] = item.end.split(':').map(Number);
    const startMin = sh * 60 + sm;
    const endMin   = eh * 60 + em;

    let status = 'upcoming';
    if (isToday) {
      if (nowMin >= startMin && nowMin < endMin) status = 'ongoing';
      else if (nowMin >= endMin) status = 'done';
      else if (startMin - nowMin <= 30) status = 'next';
    }

    const card = document.createElement('div');
    card.className = `schedule-card ${status === 'ongoing' ? 'active-class' : status === 'done' ? 'done' : ''}`;

    let badgeHTML = '';
    if (status === 'ongoing') badgeHTML = `<div class="scard-badge badge-ongoing">Sedang Berlangsung</div>`;
    else if (status === 'next') badgeHTML = `<div class="scard-badge badge-next">Berikutnya</div>`;
    else if (status === 'done') badgeHTML = `<div class="scard-badge badge-done">Selesai</div>`;

    card.innerHTML = `
      <div class="scard-time-block">
        <div class="scard-start">${item.start}</div>
        <div class="scard-end">${item.end}</div>
      </div>
      <div class="scard-divider"></div>
      <div class="scard-body">
        <div class="scard-subject">${item.m}</div>
        <div class="scard-meta"><span>🏫 ${item.r}</span>${item.g ? `<span>👤 ${item.g}</span>` : ''}</div>
      </div>
      ${badgeHTML}
    `;
    list.appendChild(card);
  });
}

// ─── BUILD WEEK GRID ───
function buildWeekGrid() {
  const grid = document.getElementById('week-grid');
  grid.innerHTML = '';
  const todayName = DAYS_ID[new Date().getDay()];

  DAYS.forEach(day => {
    const items = expandSchedule(getUserSchedule(day));
    const isToday = day === todayName;

    const card = document.createElement('div');
    card.className = 'day-card';

    const header = document.createElement('div');
    header.className = `day-card-header ${isToday ? 'today-header' : ''}`;
    header.innerHTML = `
      <span class="day-name">${day}${isToday ? ' ★ Hari Ini' : ''}</span>
      <span class="lesson-badge">${items.length} pelajaran</span>
    `;
    header.onclick = () => {
      const body = card.querySelector('.day-card-body');
      body.style.display = body.style.display === 'none' ? '' : 'none';
    };

    const body = document.createElement('div');
    body.className = 'day-card-body';
    if (!isToday) body.style.display = 'none';

    if (items.length > 0) {
      const mini = document.createElement('div');
      mini.className = 'mini-schedule';
      items.forEach(item => {
        const row = document.createElement('div');
        row.className = 'mini-row';
        row.innerHTML = `
          <div class="mini-time">${item.start}–${item.end}</div>
          <div class="mini-subject">${item.m}</div>
          <div class="mini-room">${item.r}</div>
        `;
        mini.appendChild(row);
      });
      body.appendChild(mini);
    } else {
      body.innerHTML = '<p style="padding:12px 0;color:var(--gray-400);font-size:13px;">Tidak ada pelajaran</p>';
    }

    card.appendChild(header);
    card.appendChild(body);
    grid.appendChild(card);
  });
}

// ─── REMINDERS ───
function savedReminders() {
  const key = `smkn7_rem_${currentUser.nis}`;
  try {
    const stored = localStorage.getItem(key);
    reminders = stored ? JSON.parse(stored) : [];
  } catch { reminders = []; }
}

function saveReminders() {
  const key = `smkn7_rem_${currentUser.nis}`;
  try { localStorage.setItem(key, JSON.stringify(reminders)); } catch {}
}

function loadReminders() { savedReminders(); }

function addReminder() {
  const title = document.getElementById('rem-title').value.trim();
  const type  = document.getElementById('rem-type').value;
  const date  = document.getElementById('rem-date').value;
  const time  = document.getElementById('rem-time').value;
  const desc  = document.getElementById('rem-desc').value.trim();

  if (!title || !date || !time) {
    showToast('⚠️','Lengkapi Data','Judul, tanggal, dan waktu wajib diisi');
    return;
  }

  const rem = {
    id: Date.now(),
    title, type, date, time, desc,
    notified: false
  };
  reminders.unshift(rem);
  saveReminders();
  renderReminders();

  // Clear fields
  document.getElementById('rem-title').value = '';
  document.getElementById('rem-date').value = '';
  document.getElementById('rem-time').value = '';
  document.getElementById('rem-desc').value = '';

  showToast('✅','Pengingat Disimpan',`"${title}" pada ${formatDateShort(date)} ${time}`);
}

function deleteReminder(id) {
  reminders = reminders.filter(r => r.id !== id);
  saveReminders();
  renderReminders();
}

function renderReminders() {
  const list = document.getElementById('reminders-list');
  list.innerHTML = '';

  if (reminders.length === 0) {
    list.innerHTML = `<div class="empty-state"><div class="emoji">🔕</div><p>Belum ada pengingat. Tambahkan di atas!</p></div>`;
    return;
  }

  const icons = { pelajaran:'📚', tugas:'📝', ujian:'🎯', lainnya:'🔖' };
  const iconClass = { pelajaran:'icon-pelajaran', tugas:'icon-tugas', ujian:'icon-ujian', lainnya:'icon-lainnya' };

  reminders.forEach(rem => {
    const card = document.createElement('div');
    card.className = 'reminder-card';
    const isPast = new Date(`${rem.date}T${rem.time}`) < new Date();
    card.style.opacity = isPast ? '0.6' : '1';

    card.innerHTML = `
      <div class="reminder-icon ${iconClass[rem.type]}">${icons[rem.type]}</div>
      <div class="reminder-body">
        <div class="reminder-title">${rem.title}</div>
        ${rem.desc ? `<div class="reminder-desc">${rem.desc}</div>` : ''}
        <div class="reminder-time-badge">🕐 ${formatDateShort(rem.date)} · ${rem.time}${isPast ? ' · Sudah lewat' : ''}</div>
      </div>
      <button class="btn-delete-reminder" onclick="deleteReminder(${rem.id})" title="Hapus">✕</button>
    `;
    list.appendChild(card);
  });
}

// ─── NOTIFICATION ───
function checkNotifPermission() {
  if (!('Notification' in window)) return;
  if (Notification.permission === 'default') {
    document.getElementById('notif-banner').style.display = 'flex';
  }
}

function requestNotifPermission() {
  if (!('Notification' in window)) {
    showToast('❌','Tidak Didukung','Browser ini tidak mendukung notifikasi');
    return;
  }
  Notification.requestPermission().then(perm => {
    if (perm === 'granted') {
      document.getElementById('notif-banner').style.display = 'none';
      showToast('🔔','Notifikasi Aktif','Kamu akan mendapat pengingat otomatis!');
    } else {
      showToast('⚠️','Ditolak','Aktifkan notifikasi di pengaturan browser');
    }
  });
}

function checkReminders() {
  const now = new Date();
  reminders.forEach(rem => {
    if (rem.notified) return;
    const remDate = new Date(`${rem.date}T${rem.time}`);
    const diffMs = remDate - now;
    // Fire if within 1 minute window
    if (diffMs >= 0 && diffMs <= 60000) {
      rem.notified = true;
      saveReminders();
      fireNotification(rem);
    }
  });
}

function fireNotification(rem) {
  const icons = { pelajaran:'📚', tugas:'📝', ujian:'🎯', lainnya:'🔖' };
  const icon = icons[rem.type] || '🔔';

  showToast(icon, rem.title, rem.desc || `Pengingat: ${rem.time}`);

  if ('Notification' in window && Notification.permission === 'granted') {
    new Notification(`${icon} ${rem.title}`, {
      body: rem.desc || `Pengingat jadwal SMKN 7 Semarang`,
      icon: '',
      tag: `smkn7_${rem.id}`
    });
  }
}

// ─── TOAST ───
function showToast(icon, title, body) {
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  toast.className = 'toast';
  toast.innerHTML = `
    <div class="toast-icon">${icon}</div>
    <div class="toast-text">
      <div class="toast-title">${title}</div>
      <div class="toast-body">${body}</div>
    </div>
  `;
  container.appendChild(toast);
  setTimeout(() => {
    toast.classList.add('hide');
    setTimeout(() => toast.remove(), 300);
  }, 4000);
}

// ─── TABS ───
function switchTab(tab, btn) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById(`tab-${tab}`).classList.add('active');
  btn.classList.add('active');
}

// ─── UTILS ───
function formatDateID(d) {
  return d.toLocaleDateString('id-ID', { day:'numeric', month:'long', year:'numeric' });
}
function formatDateShort(str) {
  const d = new Date(str + 'T00:00:00');
  return d.toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' });
}

// ─── INIT ───
// Set default date for reminder input
document.addEventListener('DOMContentLoaded', () => {
  const today = new Date().toISOString().split('T')[0];
  document.getElementById('rem-date').value = today;
});
</script>
